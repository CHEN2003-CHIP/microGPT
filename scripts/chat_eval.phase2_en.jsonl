{"id":"identity_phase2","prompt":"Who are you?","category":"identity","required":true,"checks":{"contains_any":["microGPT"],"min_chars":20,"forbidden_contains":["...","The United States","people who"]},"notes":"Should keep the identity anchor without drifting into unrelated text."}
{"id":"tree_definition","prompt":"What is a tree?","category":"open_qa","required":true,"checks":{"contains_any":["plant","trunk","branches"],"min_chars":25,"forbidden_contains":["...","The United States","people who"]},"notes":"Catches collapse to '.' and unrelated rambling."}
{"id":"tokenizer_brief","prompt":"Answer in one short sentence: what does a tokenizer do?","category":"open_qa","checks":{"contains_any":["token","text"],"min_chars":25,"regex_any":["[A-Za-z0-9]\\.$"],"forbidden_contains":["...",".."]},"notes":"Should end as a clean sentence."}
{"id":"file_path_two_sentences","prompt":"Explain what a file path is in two short sentences.","category":"explanation","checks":{"contains_any":["file","computer","path"],"min_chars":45,"regex_any":["\\.$"],"forbidden_contains":["...","The United States"]},"notes":"Encourages a medium-length complete answer."}
{"id":"clarification_question","prompt":"The request is unclear. Ask a short follow-up question instead of guessing.","category":"clarification","required":true,"checks":{"contains_any":["clarify","what would you like","what do you mean"],"min_chars":18,"regex_any":["\\?$"],"forbidden_contains":["..."]},"notes":"Should ask a short follow-up instead of answering randomly."}
{"id":"unsure_response","prompt":"If you are unsure, say I am not sure.","category":"refusal","required":true,"checks":{"exact":["I am not sure.","I am not sure"]},"notes":"Keeps the uncertainty anchor intact."}
{"id":"clean_ending_checkpoint","prompt":"Please answer naturally and end with a complete sentence: what is a checkpoint?","category":"clean_endings","checks":{"contains_any":["checkpoint","model","training","state"],"min_chars":40,"regex_any":["[A-Za-z0-9]\\.$"],"forbidden_contains":["...",".."]},"notes":"Flags half-sentence endings."}
{"id":"project_brief","prompt":"What is this project?","category":"project","checks":{"contains_any":["project","tokenizer","SFT","inference","training"],"min_chars":35,"forbidden_contains":["...","people who"]},"notes":"Should produce a short but grounded project description."}
